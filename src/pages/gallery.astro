---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import GalleryCard from '@/components/gallery-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'

const entries = await getCollection('albums')

// Group entries by album name
const albumMap = new Map<string, typeof entries>()
for (const entry of entries) {
  const { album: name } = entry.data
  if (!albumMap.has(name)) albumMap.set(name, [])
  albumMap.get(name)!.push(entry)
}

const albums = [...albumMap.entries()]
  .map(([name, photos]) => {
    const cover = photos[1]
    return {
      name,
      cover: cover.data.cover,
      coverAlt: cover.data.coverAlt,
      count: photos.length,
      pubDate: photos[0].data.pubDate,
    }
  })
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf())

const selfPortrait = `${import.meta.env.SELF_PORTRAIT}`
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Gallery" />
  <Breadcrumbs items={[{ label: 'Gallery', icon: 'lucide:album' }]} />

  <section>
    <div class="prose mb-8">
      <h1 class="font-cooper m-0 text-2xl font-black">photo & film dude</h1>
      That's me with the first camera I ever picked up, a <Link
        href="https://www.dpreview.com/articles/8401177820/panals80"
        external>Panasonic Lumix DMC-LS80</Link
      > that belonged to my family.Then came the smartphones, Windows Phone, ZTE,
      whatever I had at the time. Around 2020 I bought a DSLR, which I still shoot
      with. Most recently a Pentax 17, my first film camera. I <Link
        href="https://www.youtube.com/watch?v=zI1eLwVuSeI"
        external>can't get enough</Link
      > of it.
      <div
        class="border-foreground mx-auto my-6 h-48 w-48 overflow-hidden border"
      >
        <Image
          src={selfPortrait}
          alt={'self portrait'}
          quality="high"
          width="192"
          height="192"
          class="h-full w-full object-cover object-center"
        />
      </div>
      <div class="grid gap-4 lg:grid-cols-2">
        {albums.map((album) => <GalleryCard album={album} />)}
      </div>
    </div>
  </section>
</Layout>
