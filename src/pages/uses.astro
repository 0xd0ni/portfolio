---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Uses" />
  <Breadcrumbs items={[{ label: 'Uses', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <h1 class="font-cooper m-0 text-2xl font-black">Uses</h1>
      <div class="prose mb-8">
        <p>
          <b>Tools and tech I use.</b> Here are some of them.
        </p>
        <h3>At my desk</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link
              href="https://www.fnac.pt/Portatil-Gaming-OMEN-by-HP-15-dc0035np-Computador-Portatil-Computador-Portatil-Gaming/a6474112"
              external>OMEN by HP 15-dc0035np</Link
            >, my daily driver running <Link
              href="https://garudalinux.org/"
              external>Garuda Linux</Link
            >, nicknamed <Link href="https://yokai.com/kinko-gold/" external
              >kinko</Link
            >
          </li>
          <li>
            <Link
              href="https://www.lenovo.com/us/en/p/laptops/thinkpad/thinkpadt/thinkpad-t460/22tp2tt4600"
              external>ThinkPad T460</Link
            >, my <Link
              href="https://i.kym-cdn.com/editorials/icons/mobile/000/001/508/hackerman-icon.jpg"
              external>hackerman</Link
            > laptop running <Link href="https://fedoraproject.org/" external
              >Fedora 43</Link
            >, nicknamed <Link href="https://yokai.com/isogashi/" external
              >isogashi</Link
            >
          </li>
          <li>
            <Link
              href="https://www.fnac.pt/Monitor-HP-M24f-FHD-24-Monitor-Monitor-LED/a9669734"
              external>Monitor HP M24f 23,8''</Link
            >, monitor
          </li>
          <li>
            <Link
              href="https://electronics.sony.com/audio/headphones/headband/p/wh1000xm4-b"
              external>Sony WH-1000XM4</Link
            >, wireless noise-cancelling headphones
          </li>
          <li>
            <Link
              href="https://www.razer.com/gaming-mice/razer-orochi-v2"
              external>Razer Orochi V2</Link
            >, wireless mouse
          </li>
          <li>
            <Link href="https://en.sharkoon.com/product/SGK50S4" external
              >Sharkoon SKILLER SGK50 S4</Link
            >, mechanical keyboard
          </li>
          <li>
            <Link
              href="https://www.ikea.com/pt/pt/p/markus-cadeira-giratoria-vissle-cinz-esc-70261150/"
              external>IKEA MARKUS</Link
            >, office chair
          </li>
        </ul>
        <hr />
        <h2>On my laptop</h2>
        <h3>Communication</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link href="https://discord.com/" external>Discord</Link>, chat and
            communities
          </li>
          <li>
            <Link href="https://www.whatsapp.com/" external>WhatsApp Web</Link>,
            family chat
          </li>
        </ul>
        <h3>Dev environment</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link href="https://alacritty.org/" external>Alacritty</Link>,
            terminal
          </li>
          <li>
            <Link href="https://www.jetbrains.com/lp/mono/" external
              >JetBrains Mono</Link
            >, terminal font
          </li>
          <li>
            <Link
              href="https://en.wikipedia.org/wiki/Bash_(Unix_shell)"
              external>Bash</Link
            >, shell
          </li>
          <li>
            <Link href="https://code.visualstudio.com/" external
              >Visual Studio Code</Link
            >, editor
          </li>
          <li>
            <Link href="https://i3wm.org/" external>i3</Link>, window manager
          </li>
          <li>
            <Link href="https://archlinux.org/pacman/" external>Pacman</Link>,
            package manager (kinko)
          </li>
          <li>
            <Link href="https://dnf.readthedocs.io/" external>DNF</Link>,
            package manager (isogashi)
          </li>
        </ul>
        <h3>File management</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link href="https://infinitedigits.co/croc/" external>croc</Link>,
            secure file transfer between two computers
          </li>
          <li>
            <Link href="https://localsend.org/" external>LocalSend</Link>,
            cross-platform AirDrop alternative
          </li>
          <li>
            <Link href="https://syncthing.net/" external>Syncthing</Link>,
            continuous file synchronization
          </li>
        </ul>
        <h3>Multimedia</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link href="https://spotify.com" external>Spotify</Link>, music
            player
          </li>
          <li>
            <Link href="https://www.videolan.org/vlc/" external>VLC</Link>,
            video player
          </li>
          <li>
            <Link href="https://rawtherapee.com/" external>RawTherapee</Link>,
            free cross-platform raw image processor
          </li>
          <li>
            <Link href="https://github.com/CyberTimon/RapidRAW" external
              >RapidRAW</Link
            >, modern high-performance Lightroom alternative
          </li>
        </ul>
        <h3>Office</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link href="https://drive.google.com/" external>Google Drive</Link>,
            office suite
          </li>
          <li>
            <Link href="https://meet.google.com/" external>Google Meet</Link>,
            online meetings
          </li>
        </ul>
        <h3>Productivity</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link href="https://www.mozilla.org/en-US/firefox/" external
              >Firefox</Link
            >, web browser
          </li>
          <li>
            <Link href="https://obsidian.md/" external>Obsidian</Link>, personal
            knowledge base
          </li>
        </ul>
        <h3>Security</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link
              href="https://en.wikipedia.org/wiki/Google_Authenticator"
              external>Google Authenticator</Link
            >, 2FA authenticator
          </li>
          <li>
            <Link href="https://bitwarden.com/" external>Bitwarden</Link>,
            password manager
          </li>
        </ul>
        <hr />
        <h2>Photography gear</h2>
        <h3>Cameras</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link
              href="https://us.ricoh-imaging.com/product/pentax-17/"
              external>Pentax 17</Link
            >, half-frame 35mm film camera
          </li>
          <li>
            <Link href="https://www.canon.co.uk/cameras/eos-250d/" external
              >Canon EOS 250D</Link
            >, entry-level DSLR
          </li>
        </ul>
        <h3>Lenses</h3>
        <ul class="list-disc" style="margin-left: 2rem;">
          <li>
            <Link
              href="https://www.canon.co.uk/lenses/ef-s-18-55mm-f-3-5-5-6-is-ii-lens/"
              external>Canon EF-S 18-55mm f/3.5-5.6</Link
            >, kit zoom lens
          </li>
          <li>
            <Link
              href="https://www.canon.co.uk/lenses/ef-50mm-f-1-8-stm-lens/"
              external>Canon EF 50mm f/1.8 STM</Link
            >, nifty fifty prime lens
          </li>
        </ul>
        <p class="text-muted-foreground text-sm">
          Last modified: <b>7 April 2026</b>
        </p>
        <p class="text-muted-foreground text-sm">
          Inspired by <Link href="https://uses.tech/" external>uses.tech</Link>.
        </p>
        <hr />
        <h2>Changelog</h2>
        <ul class="space-y-2 pl-4">
          <li>06 April 2026 - v1.0 Initial version.</li>
          <li>07 April 2026 - v1.1 Updated at my desk.</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .prose h2,
  .prose h3 {
    font-family: var(--font-cooper);
  }
</style>
