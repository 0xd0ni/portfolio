{
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "doniatinterweb",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "minify": true,
  "limits": {
    "cpu_ms": 50
  }
}
